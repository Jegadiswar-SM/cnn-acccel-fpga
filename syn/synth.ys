# Yosys synthesis script for cnn_top
read_verilog -sv ../rtl/pe.v
read_verilog -sv ../rtl/mac_array.v
read_verilog -sv ../rtl/relu.v
read_verilog -sv ../rtl/cnn_regs.v
read_verilog -sv ../rtl/cnn_top.v

hierarchy -check -top cnn_top

synth -flatten

opt
fsm
opt
memory
opt
techmap
opt

abc -g AND,OR,XOR
opt
clean

tee -a synthesized/cnn_top_stats.rpt stat -width
write_verilog -noattr -noexpr synthesized/cnn_top_synth.v
write_json synthesized/cnn_top_synth.json
